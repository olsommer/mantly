# Mantly Community self-host configuration.
# Copy to .env.community and keep the generated file private.

# Local defaults. For public HTTPS, set DOMAIN to your hostname, PUBLIC_URL to
# https://<hostname>, and expose host ports 80/443 below.
DOMAIN=:80
PUBLIC_URL=http://localhost:8080
MANTLY_HTTP_PORT=8080
MANTLY_HTTPS_PORT=8443
MANTLY_VERSION=local
# If you publish a modified network-accessible build, point this to the exact
# corresponding source you offer to users under AGPL-3.0 section 13.
MANTLY_SOURCE_URL=https://github.com/olsommer/mantly

# PocketBase superuser. Used only for schema/bootstrap administration.
PB_ADMIN_EMAIL=pb-admin@example.test
PB_ADMIN_PASSWORD=replace-with-a-long-random-password

# Mantly application authentication.
JWT_SECRET=replace-with-at-least-64-random-hex-characters
SETUP_ADMIN_EMAIL=owner@example.test
SETUP_ADMIN_PASSWORD=replace-with-a-different-long-random-password
COMPANY_NAME=My Organisation

# Stable Outlook add-in identifier. Generate once and retain across upgrades.
ADDIN_ID=00000000-0000-4000-8000-000000000000

# Optional platform LLM fallback. Community administrators can instead configure
# their own provider key and OpenAI-compatible gateway from Mantly Settings.
MANTLY_MANAGED_LLM_PROVIDER=gemini
MANTLY_MANAGED_LLM_MODEL=gemini-3-flash-preview
MANTLY_MANAGED_LLM_API_KEY=
MANTLY_MANAGED_LLM_CUSTOM_BASE_URL=
MANTLY_MANAGED_LLM_CUSTOM_MODEL=

# Optional SMTP. Needed for email login codes and email-channel delivery.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
