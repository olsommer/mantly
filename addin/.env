# API Configuration
# The API base URL - automatically switches based on environment

# Development (localhost)
VITE_API_URL=http://localhost:8080

# Production (HTTPS endpoint)
# VITE_API_URL=https://api.yourdomain.com

# If not set, defaults are:
# - Development: http://localhost:3000
# - Production: https://api.example.com

# Mock Mode - Enable testing in browser without Outlook
# When enabled, the app will use mock email data instead of requiring Outlook
# Automatically enabled in development mode (npm run dev)
VITE_ENABLE_MOCK_MODE=true
