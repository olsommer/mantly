<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!--
  Mantly — Outlook Add-in Manifest
  =============================================
  How to deploy:
    1. Replace https://addin.mantly.io and https://api.mantly.io below with your production URLs
       (e.g. https://mantly.yourdomain.com)
    2. Side-load this file via Microsoft 365 Admin Centre:
       - Go to admin.microsoft.com → Settings → Integrated apps
       - Choose "Upload custom apps" and upload this file
       - Assign to the relevant users/groups
    3. The add-in will appear in Outlook as "Mantly"
       under the Home tab when an email is open.

  For local dev: the manifest.dev.xml (auto-generated by Vite) points
  to localhost:5173 — use that for testing, not this file.
-->
<OfficeApp
    xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
    xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
    xsi:type="MailApp">

  <!-- Unique add-in ID — replaced at deployment time.
       SaaS (Microsoft Store): a fixed UUID owned by Mantly.
       On-prem: a unique UUID per customer (set via a1b2c3d4-e5f6-7890-abcd-ef1234567890 env var). -->
  <Id>a1b2c3d4-e5f6-7890-abcd-ef1234567890</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Mantly</ProviderName>
  <DefaultLocale>de-DE</DefaultLocale>

  <DisplayName DefaultValue="Mantly"/>
  <Description DefaultValue="KI-gestützter E-Mail-Assistent für professionelle Teams"/>

  <IconUrl DefaultValue="https://api.mantly.io/assets/icon-64.png"/>
  <HighResolutionIconUrl DefaultValue="https://api.mantly.io/assets/icon-128.png"/>
  <SupportUrl DefaultValue="https://mantly.io"/>

  <AppDomains>
    <AppDomain>https://addin.mantly.io</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.3"/>
    </Sets>
  </Requirements>

  <!-- Fallback for older Outlook versions -->
  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://addin.mantly.io/"/>
        <RequestedHeight>450</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteMailbox</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="FunctionFile.Url"/>

          <!-- Read surface: button appears when reading a message -->
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgReadGroup">
                <Label resid="GroupLabel"/>
                <Control xsi:type="Button" id="msgReadOpenPaneButton">
                  <Label resid="TaskpaneButton.Label"/>
                  <Supertip>
                    <Title resid="TaskpaneButton.Label"/>
                    <Description resid="TaskpaneButton.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://api.mantly.io/assets/icon-16.png"/>
        <bt:Image id="Icon.32x32" DefaultValue="https://api.mantly.io/assets/icon-32.png"/>
        <bt:Image id="Icon.80x80" DefaultValue="https://api.mantly.io/assets/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="FunctionFile.Url" DefaultValue="https://addin.mantly.io/"/>
        <bt:Url id="Taskpane.Url" DefaultValue="https://addin.mantly.io/"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="Mantly"/>
        <bt:String id="TaskpaneButton.Label" DefaultValue="E-Mail analysieren"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="TaskpaneButton.Tooltip" DefaultValue="E-Mail mit Mantly analysieren und Antwort vorbereiten"/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>

</OfficeApp>
