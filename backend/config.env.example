# Mantly — Environment Configuration Template
# Copy this file to config.env and fill in your values.
# NEVER commit config.env to version control.

# ── Required ──────────────────────────────────────────────────────────────────

# LLM API keys are configured per-tenant in the admin UI (Settings page).
# No global GOOGLE_API_KEY is needed.

# ── Authentication (set REQUIRE_AUTH=true in production) ─────────────────────

# Enable JWT authentication. Defaults to false for local development.
REQUIRE_AUTH=false

# SaaS self-service signup. Set false to hide signup and block POST /api/auth/signup.
# On-prem signup is controlled by the tenant "Allow signups" setting instead.
# SAAS_SIGNUP_ENABLED=true

# JWT signing secret. Required when REQUIRE_AUTH=true.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# ── Users (for non-auth deployments) ─────────────────────────────────────────

# Comma-separated list of users in "Name:email" format.
# Used by /api/users when REQUIRE_AUTH=false.
USERS=Ana Kovac:ana@example.com,Sandro Gauch:sandro@example.com

# ── CORS ──────────────────────────────────────────────────────────────────────

# Allowed origins for CORS. Required when REQUIRE_AUTH=true (must not be "*").
# CORS_ORIGINS=https://app.mantly.io,https://addin.mantly.io

# ── Manifest ──────────────────────────────────────────────────────────────────

# Public URL used when generating the Outlook manifest.
# On-prem normally uses one public origin for all values.
# SaaS can split taskpane and asset origins.
# PUBLIC_URL=https://customer-domain.com
# ADDIN_BASE_URL=https://addin.mantly.io
# ASSET_BASE_URL=https://api.mantly.io
# MANIFEST_BASE_URL=https://customer-domain.com

# ── Gmail add-on (Google Workspace HTTP deployment) ──────────────────────────

# Public FastAPI origin used in Gmail card action URLs.
# SaaS normally uses https://api.mantly.io; on-prem can use PUBLIC_URL.
# GMAIL_ADDON_BASE_URL=https://api.mantly.io
# GMAIL_ADDON_ASSET_BASE_URL=https://api.mantly.io
# GMAIL_ADDON_APP_URL=https://app.mantly.io
#
# Enable strict Google request/user-token verification after copying values from
# Google Workspace Marketplace SDK → HTTP Deployments → Authorization Resource.
# GOOGLE_ADDON_VERIFY_REQUESTS=true
# GOOGLE_ADDON_VERIFY_USER_TOKEN=true
# GOOGLE_ADDON_OAUTH_CLIENT_ID=
# GOOGLE_ADDON_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_ADDON_AUDIENCE=

# ── PocketBase ────────────────────────────────────────────────────────────────

# URL of the PocketBase instance (default: http://localhost:8090)
# PB_URL=http://localhost:8090

# Superuser credentials for server-to-server calls (FastAPI → PocketBase).
# Create these on first run by visiting http://localhost:8090/_/
PB_ADMIN_EMAIL=
PB_ADMIN_PASSWORD=

# PocketBase data directory (Docker only — ignored in local dev)
# PB_DATA_DIR=/app/data/pb

# ── Database ──────────────────────────────────────────────────────────────────

# SQLite database path. Mount a volume in Docker to persist data.
# DB_PATH=/app/data/sqlite.db

# PostgreSQL connection URL (optional — SQLite is used if this is not set).
# When set, install psycopg2: uv sync --extra postgres
# DATABASE_URL=postgresql://user:password@localhost:5432/mantly

# ── File attachments ──────────────────────────────────────────────────────────

# Directory for dynamically generated attachment files.
# ATTACHMENTS_DIR=/app/data/attachments

# ── LangSmith tracing (optional) ─────────────────────────────────────────────

# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
# LANGSMITH_API_KEY=your-langsmith-api-key-here
# LANGSMITH_PROJECT=mantly.io

# ── Webhook SSRF protection (optional) ───────────────────────────────────────

# Comma-separated list of allowed webhook hostnames.
# If set, only these hosts are permitted in /api/admin/actions/trigger.
# ALLOWED_WEBHOOK_HOSTS=hooks.yourcrm.com,api.yourerp.com

# ── Demo/runtime fixtures (off by default) ───────────────────────────────────

# Enables seeded /demo/* routes for local demos and internal testing.
# Keep false in SaaS and customer on-prem production.
# ENABLE_DEMO_MODE=false
#
# SaaS demo tenants can use platform LLM credentials without changing tenant
# settings. DEMO_LLM_API_KEY falls back to GOOGLE_API_KEY when empty.
# DEMO_LLM_PROVIDER=gemini
# DEMO_LLM_MODEL=gemini-2.5-flash
# DEMO_LLM_API_KEY=
# DEMO_LLM_CUSTOM_BASE_URL=
# DEMO_LLM_CUSTOM_MODEL=

# ── Logging ───────────────────────────────────────────────────────────────────

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
# LOG_LEVEL=INFO

# ── Email verification (required when REQUIRE_AUTH=true) ─────────────────────

# SMTP server for sending verification emails.
# All of these are required when REQUIRE_AUTH=true.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASSWORD=your-smtp-password
# SMTP_FROM=noreply@example.com

# Public base URL of the admin SPA (used in verification email links).
# Example: https://app.mantly.io
# APP_BASE_URL=https://app.mantly.io

# Public PocketBase URL used in PocketBase verification/reset emails.
# For the hosted API proxy this is usually https://api.mantly.io/pb.
# PB_PUBLIC_URL=https://api.mantly.io/pb

# ── Stripe billing (SaaS only) ────────────────────────────────────────────────

# Stripe secret key (starts with sk_test_ or sk_live_)
# STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook signing secret (starts with whsec_)
# STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price ID for the Pro plan (starts with price_)
# STRIPE_PRO_PRICE_ID=price_...

# Stripe Price ID for the Business plan (starts with price_)
# STRIPE_BUSINESS_PRICE_ID=price_...

# Billable add-on Price IDs. Create with:
# STRIPE_SECRET_KEY=sk_... uv run python tools/setup_stripe_billing.py
# STRIPE_EXTRA_USER_PRICE_ID=price_...
# STRIPE_EXTRA_PROJECT_PRICE_ID=price_...
# STRIPE_EXTRA_EMAIL_BLOCK_PRICE_ID=price_...
# STRIPE_EXTRA_EMAIL_BLOCK_SIZE=100

# Mantly-managed LLM usage meter price.
# Meter event value is billed cost in micro currency units.
# STRIPE_LLM_USAGE_PRICE_ID=price_...
# STRIPE_LLM_METER_EVENT_NAME=mantly_llm_usage
# LLM_COST_MARKUP=1.2

# Mantly-managed LLM key. Free uses this included; paid plans use it when no BYOK key is configured.
# MANTLY_MANAGED_LLM_PROVIDER=gemini
# MANTLY_MANAGED_LLM_MODEL=gemini-2.5-flash
# MANTLY_MANAGED_LLM_API_KEY=...

# ── Dev mode ──────────────────────────────────────────────────────────────────

# Enable uvicorn auto-reload (development only)
# UVICORN_RELOAD=true
