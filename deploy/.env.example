# Mantly on-prem environment template.
# Copy to .env, fill values, then run: docker compose up -d

# Image tag. package-customer.sh pins this when a version is passed.
REGISTRY=ghcr.io/isarlabs
# VERSION=1.1.0

# Public origin.
DOMAIN=mail.yourfirm.com
PUBLIC_URL=https://mail.yourfirm.com
# PB_PUBLIC_URL defaults to ${PUBLIC_URL}/pb.
# PB_PUBLIC_URL=https://mail.yourfirm.com/pb

# Core app secrets.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
PB_ADMIN_EMAIL=admin@yourfirm.com
PB_ADMIN_PASSWORD=

# Outlook add-in ID. Generate once and keep stable forever:
# python3 -c "import uuid; print(uuid.uuid4())"
ADDIN_ID=

# License.
LICENSE_KEY=
LICENSE_SERVER_URL=https://api.mantly.io
ENABLE_DEMO_MODE=false

# Optional managed LLM fallback. Tenants can also configure BYOK in Admin.
MANTLY_MANAGED_LLM_PROVIDER=gemini
MANTLY_MANAGED_LLM_MODEL=gemini-3-flash-preview
MANTLY_MANAGED_LLM_API_KEY=
MANTLY_MANAGED_LLM_CUSTOM_BASE_URL=
MANTLY_MANAGED_LLM_CUSTOM_MODEL=
LLM_PRICE_TABLE_JSON=

# SMTP. Required for auth mail and email-channel support replies.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Support public links and machine-readable launch gate.
SUPPORT_PUBLIC_BASE_URL=
SUPPORT_PROJECT_ID=
ADMIN_AUTH_TOKEN=
SUPPORT_LAUNCH_GATE_TIMEOUT=15
# Default container bundle path is /app/data/support-launch-proof.json.
# Empty SUPPORT_LAUNCH_GATE_BUNDLE_FILE disables bundle creation.
# SUPPORT_LAUNCH_GATE_BUNDLE_FILE=/app/data/support-launch-proof.json
# SUPPORT_LAUNCH_GATE_BUNDLE_OUT=support-launch-proof.json
# SUPPORT_LAUNCH_GATE_COPY_BUNDLE=true
SUPPORT_CHANNEL_ACTIVATION_PLAN_OUT=support-channel-activation-plan.json
SUPPORT_CHANNEL_ACTIVATION_SECRETS_OUT=support-channel-activation-secrets.env
SUPPORT_CHANNEL_ACTIVATION_WRITE_SECRETS=true

# Internal support cron/API tokens. Use random values when external cron calls
# /api/internal/support/* endpoints.
SUPPORT_SYNC_TOKEN=
SUPPORT_DELIVERY_TOKEN=
SUPPORT_CRM_SYNC_TOKEN=
SUPPORT_CRM_WEBHOOK_TOKEN=
SUPPORT_SLA_TOKEN=

# Optional in-process support schedulers. Leave at 0 when using external cron.
SUPPORT_SYNC_INTERVAL_SECONDS=0
SUPPORT_SYNC_TENANT_ID=
SUPPORT_SYNC_PROJECT_ID=
SUPPORT_SYNC_LIMIT=25
SUPPORT_DELIVERY_INTERVAL_SECONDS=0
SUPPORT_DELIVERY_TENANT_ID=
SUPPORT_DELIVERY_PROJECT_ID=
SUPPORT_DELIVERY_LIMIT=25
SUPPORT_CRM_SYNC_INTERVAL_SECONDS=0
SUPPORT_CRM_SYNC_TENANT_ID=
SUPPORT_CRM_SYNC_PROJECT_ID=
SUPPORT_CRM_SYNC_LIMIT=25
SUPPORT_SLA_INTERVAL_SECONDS=0
SUPPORT_SLA_TENANT_ID=
SUPPORT_SLA_PROJECT_ID=
SUPPORT_SLA_LIMIT=100

# Channel secret fallbacks. Prefer Admin Settings > project secrets for
# tenant-specific values.
SUPPORT_CHANNEL_WEBHOOK_TOKEN=
SUPPORT_SLACK_SIGNING_SECRET=
SUPPORT_SLACK_WEBHOOK_TOKEN=
SUPPORT_SLACK_BOT_TOKEN=
SUPPORT_SLACK_CLIENT_ID=
SUPPORT_SLACK_CLIENT_SECRET=
SUPPORT_SLACK_OAUTH_STATE_SECRET=
SUPPORT_SLACK_OAUTH_SCOPES=
SUPPORT_TEAMS_WEBHOOK_TOKEN=
SUPPORT_TEAMS_APP_ID=
SUPPORT_TEAMS_APP_PASSWORD=
SUPPORT_DISCORD_WEBHOOK_TOKEN=
SUPPORT_DISCORD_BOT_TOKEN=
SUPPORT_TELEGRAM_WEBHOOK_TOKEN=
SUPPORT_TELEGRAM_SECRET_TOKEN=
SUPPORT_TELEGRAM_BOT_TOKEN=
SUPPORT_WHATSAPP_WEBHOOK_TOKEN=
SUPPORT_WHATSAPP_VERIFY_TOKEN=
SUPPORT_WHATSAPP_APP_SECRET=
SUPPORT_WHATSAPP_ACCESS_TOKEN=
SUPPORT_WHATSAPP_PHONE_NUMBER_ID=
SUPPORT_TWILIO_WEBHOOK_TOKEN=
SUPPORT_TWILIO_ACCOUNT_SID=
SUPPORT_TWILIO_AUTH_TOKEN=
SUPPORT_TWILIO_FROM_NUMBER=
SUPPORT_TWILIO_MESSAGING_SERVICE_SID=
SUPPORT_IMAP_PASSWORD=

# Optional Teams/Discord bridge sidecar. Start with:
# docker compose --profile support-bridge up -d support-bridge
SUPPORT_BRIDGE_PORT=8095
SUPPORT_BRIDGE_PROJECT_ID=
SUPPORT_BRIDGE_TENANT_ID=
SUPPORT_BRIDGE_TOKEN=
SUPPORT_BRIDGE_TOKEN_ENV=
SUPPORT_BRIDGE_TOKEN_HEADER=X-Support-Sync-Token
SUPPORT_BRIDGE_INBOUND_TOKEN=
SUPPORT_BRIDGE_SIGNATURE_SECRET=
SUPPORT_BRIDGE_SIGNATURE_SECRET_ENV=
SUPPORT_BRIDGE_SIGNATURE_HEADER=X-Support-Signature
SUPPORT_BRIDGE_SIGNATURE_TIMESTAMP_HEADER=X-Support-Signature-Timestamp
SUPPORT_BRIDGE_TIMEOUT_SECONDS=15

# Optional Discord Gateway worker. Start with:
# docker compose --profile discord-gateway up -d discord-gateway
SUPPORT_BRIDGE_DISCORD_CHANNEL_KEY=discord-main
SUPPORT_BRIDGE_DISCORD_BOT_TOKEN=
SUPPORT_BRIDGE_DISCORD_BOT_TOKEN_ENV=SUPPORT_DISCORD_BOT_TOKEN
SUPPORT_BRIDGE_DISCORD_GATEWAY_URL=
SUPPORT_BRIDGE_DISCORD_GATEWAY_EVENTS=
SUPPORT_BRIDGE_DISCORD_GATEWAY_INTENTS=
SUPPORT_BRIDGE_RECONNECT_SECONDS=5

# Optional observability.
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
